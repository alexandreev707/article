OXAPAY_ENABLED=true
OXAPAY_SANDBOX_ENABLED=false
OXAPAY_SANDBOX_MERCHANT=sandbox
OXAPAY_BASE_URL=https://api.oxapay.com
# Merchant key = invoices / payment link (POST /merchants/request). NOT the same as Payout key.
OXAPAY_MERCHANT_API_KEY=your_merchant_api_key
OXAPAY_PAYOUT_API_KEY=your_payout_api_key
OXAPAY_CALLBACK_URL=https://article-aolc.onrender.com/api/checkout/oxapay/callback
OXAPAY_RETURN_URL=https://article-aolc.onrender.com/orders
OXAPAY_INVOICE_LIFETIME_MINUTES=30
OXAPAY_CURRENCY=USD

# Payout to seller wallet (POST /v1/payout); amount uses order total in this currency (e.g. USDT)
OXAPAY_PAYOUT_CURRENCY=USDT
# Required by OxaPay for USDT; default TRC20 (TRON). Use BEP20, ERC20, etc. if needed
OXAPAY_PAYOUT_NETWORK=TRC20
